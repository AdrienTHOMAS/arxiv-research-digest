# Database
DATABASE_URL=postgresql+asyncpg://arxiv:arxiv@localhost:5432/arxiv_digest

# API Authentication
API_KEY=change-me-to-a-secure-random-string

# Cache
CACHE_DIR=.cache

# Webhooks (comma-separated URLs for digest delivery)
WEBHOOK_URLS=

# Logging
LOG_LEVEL=INFO

# CORS (comma-separated origins)
CORS_ORIGINS=["*"]

# Topics configuration file path
TOPICS_FILE=config/topics.yaml

# Application
APP_NAME=arxiv-research-digest
APP_VERSION=2.0.0
